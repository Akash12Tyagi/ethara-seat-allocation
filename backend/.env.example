# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./ethara.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/ethara

# Optional - enables Claude-phrased AI assistant responses. Without this, the
# assistant falls back to the deterministic rule-based intent parser (see
# app/services/ai_assistant.py), which is fully functional on its own.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENVIRONMENT=development
